<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lianggeshipin.www.dao.IPlotDao">
    
    <insert id="add" parameterType="com.lianggeshipin.www.model.Plot" keyProperty="id" useGeneratedKeys="true">
    	insert plot(id,animated_id,plot_name,which_episode,video_url,img_url,title,meta,intro) 
    	VALUE(#{id},#{animatedID},#{plotName},#{whichEpisode},#{videoUrl},#{imgUrl},#{title},#{meta},#{intro})
    </insert>
    
    <delete id="del" parameterType="int">
    	DELETE FROM plot where id=#{id}
    </delete>
    
    <update id="up" parameterType="com.lianggeshipin.www.model.Plot">
    	UPDATE plot set id=#{id},animated_id=#{animatedID},plot_name=#{plotName},
    		which_episode=#{whichEpisode},video_url=#{videoUrl},img_url=#{imgUrl},
    		title=#{title},meta=#{meta},intro=#{intro}  
    	where id=#{id}
    </update>
    
    <select id="queOne" parameterType="int" resultType="com.lianggeshipin.www.model.Plot">
    	SELECT id,animated_id AS animatedID,plot_name AS plotName,which_episode AS whichEpisode,
    	video_url AS videoUrl,img_url AS imgUrl,title,meta,intro 
    	from plot 
    	WHERE id=#{id};
    </select>
    
    <select id="queListByAnimatedID" parameterType="int" resultType="com.lianggeshipin.www.model.Plot">
    	SELECT id,animated_id AS animatedID,plot_name AS plotName,which_episode AS whichEpisode,
    	video_url AS videoUrl,img_url AS imgUrl,title,meta,intro  
    	from plot
    	WHERE animated_id=#{animatedID};
    </select>
    
</mapper>
